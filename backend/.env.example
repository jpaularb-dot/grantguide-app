# ───────────────────────────── GrantGuide Backend (Node.js) ───────────────────
# Copy this file to ".env" and fill in your values. NEVER commit the real .env.

# Server
PORT=4000
APP_URL=http://localhost:4000
APP_DEBUG=false

# Auth — generate a long random string.
# (in a terminal you can run:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" )
JWT_SECRET=replace-with-a-long-random-secret

# CORS — the origin your frontend runs on (Vite default is 5173)
CORS_ORIGIN=http://localhost:5173

# Database — XAMPP defaults shown. Start MySQL in the XAMPP Control Panel,
# then import database/grantguide.sql via phpMyAdmin (it creates the DB).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=grantguide
DB_USER=root
DB_PASS=

# Cloudinary (optional). Leave blank to store uploaded files locally in /uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
